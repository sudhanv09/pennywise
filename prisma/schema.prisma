generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(ulid())
  email         String    @unique
  password      String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String?
  sessions      Session[]
  verifications Verification[]
  accounts Account[]
  transactions Transaction[]

  @@map("user")
}

model Session {
  id           String   @id @default(ulid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  userId    String    
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification")
}

enum Category {
  Income
  Expense
  Transfer
}

enum TransactionCategory {
  Shopping
  Bills
  Food
  Groceries
  Transit
  Income
  Extra
}

model Transaction {
  id String @id @default(ulid())
  title String?
  amount Decimal
  description String?
  category Category
  transactionCategory TransactionType?

  createdAt  DateTime? @default(now())
  updatedAt    DateTime          @updatedAt

  userId       String            
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String            
  account      Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transferAccountId String?       // Destination account for transfers
  transferAccount   Account?      @relation(fields: [transferAccountId], references: [id], onDelete: Cascade, name: "TransferTo")

  @@map("transactions")
}

model Account {
  id String @id @default(ulid())
  name String
  currency String @default("USD")
  balance Decimal @default(0.0)

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

model Goal {
  id          String    @id @default(ulid())
  name        String    
  targetAmount Decimal  
  currentAmount Decimal @default(0.00) // Current savings
  deadline    DateTime?

  userId      String    
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String?   
  account     Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("goal")
}

model Loan {
  id             String    @id @default(ulid())
  name           String    
  totalAmount    Decimal   
  remainingAmount Decimal  
  interestRate   Float?  
  monthlyPayment Decimal?

  userId         String    
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId      String?  
  account        Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transactions   Transaction[]
   
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("loan")
}